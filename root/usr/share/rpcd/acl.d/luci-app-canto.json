{
	"luci-app-canto": {
		"description": "Grant access to canto configuration",
		"read": {
			"file": {
				"/etc/canto/scripts/update_subscriptions.uc": [ "exec" ],
				"/var/run/canto/canto.log": [ "read" ],
				"/var/run/canto/sing-box-c.log": [ "read" ],
				"/var/run/canto/sing-box-s.log": [ "read" ]
			},
			"ubus": {
				"service": [ "list" ],
				"luci.canto": [ "*" ]
			},
			"uci": [ "canto" ]
		},
		"write": {
			"file": {
				"/tmp/canto_certificate.tmp": [ "write" ]
			},
			"uci": [ "canto" ]
		}
	}
}
